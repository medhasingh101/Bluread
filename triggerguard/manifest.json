{
  "manifest_version": 3,
  "name": "SafeView",
  "description": "AI-powered content protection \u2014 detects and blurs triggering content",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "*://*.instagram.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles/overlay.css"
      ]
    },
    {
      "matches": [
        "*://*.instagram.com/*"
      ],
      "js": [
        "instagram.js"
      ],
      "css": [
        "styles/overlay.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.twitter.com/*",
        "*://*.x.com/*"
      ],
      "js": [
        "x.js"
      ],
      "css": [
        "styles/overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}